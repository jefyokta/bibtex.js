{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "typeRoots": ["./src/types","./node_modules/@types"]
  
    
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
